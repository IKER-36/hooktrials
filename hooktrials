#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
RUNTIME_DIR="$ROOT/.hooktrials"
RUNTIME_ENV="$RUNTIME_DIR/runtime.env"

die() {
  printf '%s\n' "error: $*" >&2
  exit 1
}

require() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

env_value() {
  key=$1
  [ -f "$RUNTIME_ENV" ] || return 0
  sed -n "s/^${key}=//p" "$RUNTIME_ENV" | tail -n 1
}

set_env() {
  key=$1
  value=$2
  temp="$RUNTIME_ENV.tmp"
  awk -v key="$key" -v value="$value" '
    BEGIN { found = 0 }
    index($0, key "=") == 1 { print key "=" value; found = 1; next }
    { print }
    END { if (!found) print key "=" value }
  ' "$RUNTIME_ENV" >"$temp"
  chmod 600 "$temp"
  mv "$temp" "$RUNTIME_ENV"
}

valid_domain() {
  printf '%s' "$1" | grep -Eq '^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}$'
}

valid_https_origin() {
  case "$1" in
    https://*) return 0 ;;
    *) return 1 ;;
  esac
}

generate_runtime() {
  [ -f "$RUNTIME_ENV" ] && return
  require openssl
  mkdir -p "$RUNTIME_DIR"
  chmod 700 "$RUNTIME_DIR"
  umask 077

  port=${HOOKTRIALS_PORT:-3000}
  origin=${HOOKTRIALS_ORIGIN:-http://localhost:$port}
  postgres_password=$(openssl rand -hex 24)
  redis_password=$(openssl rand -hex 24)

  cat >"$RUNTIME_ENV" <<EOF
HOOKTRIALS_PROJECT=hooktrials-selfhost
HOOKTRIALS_MODE=${HOOKTRIALS_MODE:-local}
HOOKTRIALS_BIND=${HOOKTRIALS_BIND:-127.0.0.1}
HOOKTRIALS_PORT=$port
HOOKTRIALS_ORIGIN=$origin
HOOKTRIALS_DOMAIN=
ACME_EMAIL=
DEPLOYMENT_MODE=selfhost
REGISTRATION_MODE=first-user
COOKIE_SECURE=${COOKIE_SECURE:-false}
POSTGRES_PASSWORD=$postgres_password
REDIS_PASSWORD=$redis_password
DATABASE_URL=postgresql://hooktrials:$postgres_password@postgres:5432/hooktrials
REDIS_URL=redis://:$redis_password@redis:6379/0
SESSION_SECRET=$(openssl rand -hex 48)
PAYLOAD_ENCRYPTION_KEY=$(openssl rand -hex 32)
ENDPOINTS_LIMIT=0
DAILY_EVENTS_LIMIT=0
EVENT_RETENTION_HOURS=72
MAX_BODY_BYTES=524288
EOF
  chmod 600 "$RUNTIME_ENV"
  printf '%s\n' "Generated private runtime configuration: $RUNTIME_ENV"
}

compose() {
  mode=$(env_value HOOKTRIALS_MODE)
  case "${mode:-local}" in
    domain) overlay="$ROOT/compose.domain.yml" ;;
    local | proxy) overlay="$ROOT/compose.local.yml" ;;
    *) die "unknown HOOKTRIALS_MODE: $mode" ;;
  esac
  docker compose \
    --project-directory "$ROOT" \
    --env-file "$RUNTIME_ENV" \
    -f "$ROOT/compose.yml" \
    -f "$overlay" \
    "$@"
}

show_access() {
  mode=$(env_value HOOKTRIALS_MODE)
  origin=$(env_value HOOKTRIALS_ORIGIN)
  case "${mode:-local}" in
    local) printf '%s\n' "Access: local only ($origin)" ;;
    proxy) printf '%s\n' "Access: existing HTTPS proxy ($origin)" ;;
    domain) printf '%s\n' "Access: direct public HTTPS ($origin)" ;;
  esac
}

configure_access() {
  generate_runtime
  mode=${1:-}
  if [ -z "$mode" ]; then
    printf '%s\n' "Choose how HookTrials is reached:"
    printf '%s\n' "  1) local  - this machine only"
    printf '%s\n' "  2) proxy  - your existing HTTPS reverse proxy"
    printf '%s\n' "  3) domain - direct public domain with automatic HTTPS"
    printf 'Mode [local/proxy/domain]: '
    read -r mode
  fi

  case "$mode" in
    1 | local)
      port=${2:-3000}
      printf '%s' "$port" | grep -Eq '^[0-9]{1,5}$' || die "port must be numeric"
      [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || die "port must be between 1 and 65535"
      set_env HOOKTRIALS_MODE local
      set_env HOOKTRIALS_BIND 127.0.0.1
      set_env HOOKTRIALS_PORT "$port"
      set_env HOOKTRIALS_ORIGIN "http://localhost:$port"
      set_env HOOKTRIALS_DOMAIN ""
      set_env ACME_EMAIL ""
      set_env COOKIE_SECURE false
      ;;
    2 | proxy)
      origin=${2:-}
      if [ -z "$origin" ]; then
        printf 'Public HTTPS origin (example: https://trials.example.com): '
        read -r origin
      fi
      valid_https_origin "$origin" || die "proxy origin must start with https://"
      port=${3:-3000}
      printf '%s' "$port" | grep -Eq '^[0-9]{1,5}$' || die "port must be numeric"
      [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || die "port must be between 1 and 65535"
      set_env HOOKTRIALS_MODE proxy
      set_env HOOKTRIALS_BIND 127.0.0.1
      set_env HOOKTRIALS_PORT "$port"
      set_env HOOKTRIALS_ORIGIN "${origin%/}"
      set_env HOOKTRIALS_DOMAIN ""
      set_env ACME_EMAIL ""
      set_env COOKIE_SECURE true
      ;;
    3 | domain)
      domain=${2:-}
      email=${3:-}
      if [ -z "$domain" ]; then
        printf 'Public domain (example: trials.example.com): '
        read -r domain
      fi
      if [ -z "$email" ]; then
        printf 'ACME email for certificate notices: '
        read -r email
      fi
      valid_domain "$domain" || die "invalid public domain"
      case "$email" in
        *@*.*) ;;
        *) die "invalid ACME email" ;;
      esac
      set_env HOOKTRIALS_MODE domain
      set_env HOOKTRIALS_BIND 0.0.0.0
      set_env HOOKTRIALS_PORT 443
      set_env HOOKTRIALS_ORIGIN "https://$domain"
      set_env HOOKTRIALS_DOMAIN "$domain"
      set_env ACME_EMAIL "$email"
      set_env COOKIE_SECURE true
      ;;
    *) die "mode must be local, proxy or domain" ;;
  esac

  compose config --quiet
  printf '%s\n' "Access configuration saved without rotating runtime secrets."
  show_access
  printf '%s\n' "Run ./hooktrials up to apply it."
}

external_doctor() {
  mode=$(env_value HOOKTRIALS_MODE)
  origin=$(env_value HOOKTRIALS_ORIGIN)
  if [ "${mode:-local}" = "local" ]; then
    printf '%s\n' "External access: disabled (local-only mode)."
    printf '%s\n' "Run ./hooktrials configure proxy or ./hooktrials configure domain."
    return 0
  fi
  require curl
  valid_https_origin "$origin" || die "public origin must use HTTPS"
  curl --fail --silent --show-error --max-time 15 "$origin/api/healthz" >/dev/null ||
    die "external API probe failed: $origin/api/healthz"
  printf '%s\n' "External HTTPS probe: OK ($origin)"
}

require docker
docker compose version >/dev/null 2>&1 || die "Docker Compose v2 is required"

case "${1:-up}" in
  up)
    generate_runtime
    compose up -d --build
    compose ps
    printf '\nHookTrials: %s\n' "$(env_value HOOKTRIALS_ORIGIN)"
    show_access
    printf '%s\n' "Create the first account to become installation owner."
    ;;
  down)
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    compose down
    ;;
  logs)
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    if [ -n "${2:-}" ]; then
      compose logs --tail=200 -f "$2"
    else
      compose logs --tail=200 -f
    fi
    ;;
  status)
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    compose ps
    show_access
    ;;
  doctor)
    generate_runtime
    compose config --quiet
    printf '%s\n' "Docker, Compose and configuration: OK"
    if [ "${2:-}" = "--external" ]; then external_doctor; else show_access; fi
    ;;
  configure)
    configure_access "${2:-}" "${3:-}" "${4:-}"
    ;;
  update)
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    compose build --pull
    compose up -d
    compose ps
    ;;
  backup)
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    mkdir -p "$ROOT/backups"
    backup="$ROOT/backups/hooktrials-$(date -u +%Y%m%dT%H%M%SZ).sql.gz"
    compose exec -T postgres pg_dump -U hooktrials hooktrials | gzip >"$backup"
    chmod 600 "$backup"
    printf '%s\n' "Backup created: $backup"
    ;;
  reset)
    [ "${2:-}" = "--yes" ] || die "reset deletes all HookTrials data; rerun: ./hooktrials reset --yes"
    [ -f "$RUNTIME_ENV" ] || die "HookTrials is not initialized"
    compose down --volumes
    rm -f "$RUNTIME_ENV"
    printf '%s\n' "HookTrials data and runtime secrets removed."
    ;;
  help | -h | --help)
    printf '%s\n' "Usage: ./hooktrials {up|down|logs [service]|status|doctor [--external]|configure [local|proxy|domain]|update|backup|reset --yes}"
    ;;
  *)
    printf '%s\n' "Usage: ./hooktrials {up|down|logs [service]|status|doctor [--external]|configure [local|proxy|domain]|update|backup|reset --yes}" >&2
    exit 2
    ;;
esac
