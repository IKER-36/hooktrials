{
  "name": "hooktrials",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Open-source webhook resilience and contract testing lab.",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter './packages/**' build && pnpm --parallel --filter @hooktrials/web --filter @hooktrials/api --filter @hooktrials/ingestor --filter @hooktrials/worker dev",
    "dev:stack": "./scripts/local-stack.sh up",
    "dev:stack:down": "./scripts/local-stack.sh down",
    "dev:stack:reset": "./scripts/local-stack.sh reset --yes",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @hooktrials/database db:generate",
    "db:migrate": "pnpm --filter @hooktrials/database db:migrate",
    "db:studio": "pnpm --filter @hooktrials/database db:studio"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
